# Quali Backend — Environment Variables
# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit real credentials.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
SCOPE=local                  # local | test | prod
# DEBUG=true                 # Defaults: local=true, test=true, prod=false

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://quali:quali@localhost:5432/quali

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Fernet symmetric key for encrypting sensitive data.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Firebase Authentication
# ---------------------------------------------------------------------------
# Required for JWT token verification in the auth middleware.
FIREBASE_PROJECT_ID=
